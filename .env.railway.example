# ═══════════════════════════════════════════════════════════════════
# RAILWAY ENVIRONMENT VARIABLES — Copy these into Railway Dashboard
# Settings > Variables
# ═══════════════════════════════════════════════════════════════════

# ── Core ──────────────────────────────────────────────────────────
ENVIRONMENT=PROD

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=PASTE_YOUR_NEW_64_CHAR_SECRET_HERE

# ── Database (Railway sets this automatically when you add PostgreSQL) ──
# DATABASE_URL=postgresql://... (auto-set by Railway)

# ── Redis (Railway sets this automatically when you add Redis) ─────
# REDIS_URL=redis://... (auto-set by Railway)

LEMON_SQUEEZY_API_KEY=YOUR_NEW_LEMON_SQUEEZY_API_KEY
LEMON_SQUEEZY_STORE_ID=YOUR_STORE_ID
LEMON_SQUEEZY_WEBHOOK_SECRET=YOUR_NEW_WEBHOOK_SECRET
LEMON_PRO_VARIANT_ID=1781727
LEMON_ENTERPRISE_VARIANT_ID=1781749

# ── Frontend URL (your Railway frontend URL) ───────────────────────
FRONTEND_URL=https://your-app.up.railway.app
ALLOW_ORIGINS=https://your-app.up.railway.app

# ── Sentry (from sentry.io > Settings > Projects > DSN) ───────────
SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz

# ── AI Race Engineer (FREE — Google Gemini Flash) ──────────────────
# Get your FREE key at: https://aistudio.google.com/app/apikey
# Free tier: 1,500 requests/day. No credit card required.
GEMINI_API_KEY=YOUR_NEW_GEMINI_API_KEY

# ── Frontend (Next.js) ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://your-api.up.railway.app
